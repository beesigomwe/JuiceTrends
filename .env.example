# Server host binding.
# Use 127.0.0.1 for local development (loopback only).
# Leave unset or set to 0.0.0.0 on Railway so the container accepts external traffic.
HOST=127.0.0.1

# Base URL for the app (used for OAuth redirect URIs when *_CALLBACK_URL is unset).
# Use PUBLIC_URL if the app is behind a proxy and the public URL differs.
APP_URL=http://localhost:5173
PUBLIC_URL=

# OAuth callback URLs — optional; must match each provider’s dashboard exactly.
# Production example (https://www.juicetrends.com):
# FACEBOOK_CALLBACK_URL=https://www.juicetrends.com/api/auth/facebook/callback
# INSTAGRAM_CALLBACK_URL=https://www.juicetrends.com/api/auth/instagram/callback
# TWITTER_CALLBACK_URL=https://www.juicetrends.com/api/auth/twitter/callback
# LINKEDIN_CALLBACK_URL=https://www.juicetrends.com/api/auth/linkedin/callback
# TIKTOK_CALLBACK_URL=https://www.juicetrends.com/api/auth/tiktok/callback
# PINTEREST_CALLBACK_URL=https://www.juicetrends.com/api/auth/pinterest/callback
# YOUTUBE_CALLBACK_URL=https://www.juicetrends.com/api/auth/youtube/callback
# THREADS_CALLBACK_URL=https://www.juicetrends.com/api/auth/threads/callback
FACEBOOK_CALLBACK_URL=
INSTAGRAM_CALLBACK_URL=
TWITTER_CALLBACK_URL=
LINKEDIN_CALLBACK_URL=
TIKTOK_CALLBACK_URL=
PINTEREST_CALLBACK_URL=
YOUTUBE_CALLBACK_URL=
THREADS_CALLBACK_URL=

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/socialflow

# Session (required in production)
SESSION_SECRET=generate-a-long-random-secret

# Token encryption at rest (optional; if set, access/refresh tokens are encrypted in DB)
ENCRYPTION_KEY=

# Twitter / X
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Meta (Facebook + Instagram)
META_APP_ID=
META_APP_SECRET=

# Optional: public URL that starts Instagram connect (GET /api/auth/instagram); not the Meta OAuth redirect
INSTAGRAM_AUTH_REDIRECT_URL=

# Webhook subscription verify token (GET /api/webhooks/instagram). Also accepts legacy WEBHOOK_VERIFY_TOKEN.
INSTAGRAM_VERIFY_TOKEN=
WEBHOOK_VERIFY_TOKEN=

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Pinterest
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=

# Google (YouTube)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Threads
THREADS_APP_ID=
THREADS_APP_SECRET=

# OpenAI (AI content generation + suggestion engine)
OPENAI_API_KEY=

# Seeding — required on Railway for first-deploy user creation
# Set SEED_USERS=false to skip creating admin/test accounts
ADMIN_USER=admin@yourdomain.com
ADMIN_PASS=
TEST_USER=test@yourdomain.com
TEST_PASS=
SEED_USERS=true
