# Base URL for the app (used for OAuth redirect URIs).
# Use PUBLIC_URL if the app is behind a proxy and the public URL differs.
APP_URL=http://localhost:5173
PUBLIC_URL=

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/socialflow

# Session (required in production)
SESSION_SECRET=generate-a-long-random-secret

# Token encryption at rest (optional; if set, access/refresh tokens are encrypted in DB)
ENCRYPTION_KEY=

# Twitter / X
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Meta (Facebook + Instagram)
META_APP_ID=
META_APP_SECRET=

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Pinterest
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=

# Google (YouTube)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: admin and test users for seeding
ADMIN_USER=
ADMIN_PASS=
TEST_USER=
TEST_PASS=
SEED_USERS=
